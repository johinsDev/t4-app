{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"workspaces": {
		".": {
			"ignoreDependencies": ["@upstash/redis"]
		},
		"apps/web": {
			"entry": [
				"app/**/page.tsx",
				"app/**/layout.tsx",
				"app/**/route.ts",
				"components/ui/*.tsx",
				"hooks/*.ts",
				"lib/utils.ts",
				"lib/sms/index.ts",
				"lib/whatsapp/index.ts",
				"lib/email/index.ts",
				"emails/**/*.tsx",
				"lib/cache/index.ts",
				"lib/rate-limit/index.ts",
				"lib/auth-server.ts",
				"trpc/*.{ts,tsx}",
				"db/**/*.ts",
				"trigger/**/*.ts",
				"trigger.config.ts"
			],
			"project": ["**/*.{ts,tsx,mjs}"],
			"ignoreDependencies": [
				"@react-email/preview-server",
				"client-only",
				"date-fns",
				"postcss",
				"shadcn",
				"tailwindcss",
				"tw-animate-css"
			]
		},
		"packages/typescript-config": {
			"entry": [],
			"project": [],
			"ignoreDependencies": ["next"]
		}
	}
}
