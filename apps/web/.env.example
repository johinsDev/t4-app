# ===========================================
# Database (Turso / LibSQL)
# ===========================================
# Local dev: file:local.db
# Turso:     libsql://<db-name>-<org>.turso.io
DATABASE_URL=file:local.db
# Only needed for Turso remote connections
DATABASE_AUTH_TOKEN=

# ===========================================
# Better Auth
# ===========================================
BETTER_AUTH_SECRET=development-secret-must-be-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=placeholder-google-client-id
GOOGLE_CLIENT_SECRET=placeholder-google-client-secret

# ===========================================
# SMS (json for dev, twilio for production)
# ===========================================
SMS_PROVIDER=json

# ===========================================
# WhatsApp (json for dev, twilio for production)
# ===========================================
WHATSAPP_PROVIDER=json
# Twilio WhatsApp sender number (only needed when WHATSAPP_PROVIDER=twilio)
# TWILIO_WHATSAPP_NUMBER=

# ===========================================
# Email (json for dev, resend for production)
# ===========================================
EMAIL_PROVIDER=json
# Resend API key (only needed when EMAIL_PROVIDER=resend)
# RESEND_API_KEY=
# Default sender address
# EMAIL_FROM=onboarding@resend.dev

# ===========================================
# App
# ===========================================
APP_NAME=T4 App
