# ===========================================
# Database (Turso / LibSQL)
# ===========================================
# Local dev: file:local.db
# Turso:     libsql://<db-name>-<org>.turso.io
DATABASE_URL=file:local.db
# Only needed for Turso remote connections
DATABASE_AUTH_TOKEN=

# ===========================================
# Better Auth
# ===========================================
BETTER_AUTH_SECRET=development-secret-must-be-at-least-32-chars-long
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=placeholder-google-client-id
GOOGLE_CLIENT_SECRET=placeholder-google-client-secret

# ===========================================
# SMS (json for dev, twilio for production)
# ===========================================
SMS_PROVIDER=json

# ===========================================
# WhatsApp (json for dev, twilio for production)
# ===========================================
WHATSAPP_PROVIDER=json
# Twilio WhatsApp sender number (only needed when WHATSAPP_PROVIDER=twilio)
# TWILIO_WHATSAPP_NUMBER=

# ===========================================
# Email (json for dev, resend for production)
# ===========================================
EMAIL_PROVIDER=json
# Resend API key (only needed when EMAIL_PROVIDER=resend)
# RESEND_API_KEY=
# Default sender address
# EMAIL_FROM=onboarding@resend.dev

# ===========================================
# Cache (memory for dev, upstash/redis for production)
# ===========================================
CACHE_PROVIDER=memory
# Upstash credentials (only needed when CACHE_PROVIDER=upstash)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Redis URL (only needed when CACHE_PROVIDER=redis)
# REDIS_URL=redis://localhost:6379

# ===========================================
# Rate Limit (memory for dev, upstash for production)
# ===========================================
RATE_LIMIT_PROVIDER=memory
# Upstash Redis credentials (only needed when RATE_LIMIT_PROVIDER=upstash)
# Also used by the cache upstash provider
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ===========================================
# Trigger.dev (background jobs)
# ===========================================
# Get your secret key from https://cloud.trigger.dev
# TRIGGER_SECRET_KEY=
# Override project ref (defaults to hardcoded value in trigger.config.ts)
# TRIGGER_PROJECT_ID=

# ===========================================
# App
# ===========================================
APP_NAME=T4 App
